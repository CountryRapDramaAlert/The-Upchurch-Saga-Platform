rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              request.auth.token.email == 'didhesaythatreally@gmail.com' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true));
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerifiedUser() { 
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'didhesaythatreally@gmail.com'); 
    }
    function isNotBanned() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false;
    }

    // --- Entity Validation Blueprints ---

    function isValidArtist(data) {
      return data.keys().hasAll(['name', 'email', 'bio', 'genres', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.bio is string && data.bio.size() <= 10000 &&
             data.genres is list && data.genres.size() > 0 && data.genres.size() <= 10 &&
             data.genres[0] is string &&
             data.status in ['pending', 'approved', 'rejected', 'changes_requested'];
    }

    function isValidArtistUpdate(data) {
      return data.keys().hasAll(['artistId', 'artistName', 'type', 'description', 'createdAt']) &&
             data.artistId is string && data.artistId.size() <= 128 &&
             data.artistName is string && data.artistName.size() <= 200 &&
             data.type in ['profile_created', 'profile_updated', 'music_added'] &&
             data.description is string && data.description.size() <= 1000 &&
             data.createdAt is string;
    }

    function isValidCreator(data) {
      return data.keys().hasAll(['name', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.role is string && data.role.size() <= 100;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'category']) &&
             data.title is string && data.title.size() <= 300 &&
             data.date is string && // Simplified for rule engine
             data.category is string && data.category.size() <= 50;
    }

    function isValidEvidence(data) {
      return data.keys().hasAll(['title', 'type', 'submittedBy', 'status']) &&
             data.title is string && data.title.size() <= 500 &&
             data.type in ['image', 'video', 'link', 'text', 'document'] &&
             data.submittedBy is string && data.submittedBy.size() <= 128;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'username']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.username.matches('^[a-zA-Z0-9_]+$');
    }

    function isValidReport(data) {
      return data.keys().hasAll(['targetId', 'targetType', 'reason', 'reporterId', 'status', 'createdAt']) &&
             data.targetId is string && data.targetId.size() <= 128 &&
             data.targetType in ['evidence', 'comment'] &&
             data.reason in ['copyright', 'doxxing', 'harassment', 'spam', 'other'] &&
             data.reporterId == request.auth.uid &&
             data.status == 'pending' &&
             data.createdAt == request.time;
    }

    function isValidDossierProfile(data) {
      return data.keys().hasAll(['name', 'role', 'status']) &&
             data.name is string && data.name.size() > 0 &&
             data.role in ['moderator', 'subject', 'community_member'] &&
             data.status in ['active', 'monitored', 'pending'];
    }

    function isValidStream(data) {
      return data.keys().hasAll(['url', 'videoId', 'title', 'creatorName', 'status']) &&
             data.url is string && data.url.size() <= 1000 &&
             data.videoId is string && data.videoId.size() <= 100 &&
             data.title is string && data.title.size() <= 300 &&
             data.creatorName is string && data.creatorName.size() <= 200 &&
             data.status in ['queued', 'ingesting', 'transcribing', 'analyzing', 'live', 'complete'];
    }

    function isValidAiEvent(data) {
      return data.keys().hasAll(['streamId', 'timestamp', 'timestampSeconds', 'type', 'title', 'severity', 'confidence', 'explanation', 'snippet']) &&
             data.streamId is string && data.streamId.size() <= 128 &&
             data.timestamp is string && data.timestamp.size() <= 20 &&
             data.timestampSeconds is number &&
             data.type is string && data.type.size() <= 100 &&
             data.title is string && data.title.size() <= 300 &&
             data.severity in ['low', 'medium', 'high'] &&
             data.confidence is number &&
             data.explanation is string && data.explanation.size() <= 5000 &&
             data.snippet is string && data.snippet.size() <= 5000;
    }

    function isValidUserAnnotation(data) {
      return data.keys().hasAll(['streamId', 'timestamp', 'timestampSeconds', 'text']) &&
             data.streamId is string && data.streamId.size() <= 128 &&
             data.timestamp is string && data.timestamp.size() <= 20 &&
             data.timestampSeconds is number &&
             data.text is string && data.text.size() <= 2000;
    }

    // --- Collections ---

    match /streams/{streamId} {
      allow read: if true;
      allow create: if isValidId(streamId) && isSignedIn() && isNotBanned() && isValidStream(incoming());
      allow update: if isValidId(streamId) && (isAdmin() || (isSignedIn() && isNotBanned() && isValidStream(incoming())));
      allow delete: if isValidId(streamId) && isAdmin();
    }

    match /ai_events/{eventId} {
      allow read: if true;
      allow create: if isValidId(eventId) && (isAdmin() || (isSignedIn() && isNotBanned() && isValidAiEvent(incoming())));
      allow update: if isValidId(eventId) && (isAdmin() || (isSignedIn() && isNotBanned() && (incoming().diff(existing()).affectedKeys().hasOnly(['userFlaggedCount', 'pinned']))));
      allow delete: if isValidId(eventId) && isAdmin();
    }

    match /user_annotations/{annotationId} {
      allow read: if true;
      allow create: if isValidId(annotationId) && isSignedIn() && isNotBanned() && isValidUserAnnotation(incoming());
      allow update: if isValidId(annotationId) && (isAdmin() || (isSignedIn() && isNotBanned() && (incoming().diff(existing()).affectedKeys().hasOnly(['votes']))));
      allow delete: if isValidId(annotationId) && (isAdmin() || (isSignedIn() && resource.data.get('userEmail', '') == request.auth.token.email));
    }

    match /creators/{creatorId} {
      allow read: if true;
      allow write: if isValidId(creatorId) && isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isValidId(eventId) && isAdmin();
    }

    match /conflicts/{conflictId} {
      allow read: if true;
      allow write: if isValidId(conflictId) && isAdmin();
    }

    match /lawsuits/{lawsuitId} {
      allow read: if true;
      allow write: if isValidId(lawsuitId) && isAdmin();
    }

    match /evidence/{evidenceId} {
      allow read: if isAdmin() || resource.data.status == 'approved' || isOwner(resource.data.submittedBy);
      
      allow create: if isValidId(evidenceId) && isVerifiedUser() && isNotBanned() && isValidEvidence(incoming()) && incoming().status == 'pending' && incoming().submittedBy == request.auth.uid;
      
      allow update: if isValidId(evidenceId) && ((isAdmin()) || (
        isValidEvidence(incoming()) && isNotBanned() && (
          // Action: Upvote
          (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['votes']) && incoming().votes == existing().votes + 1) ||
          // Action: Edit
          (
            isOwner(existing().submittedBy) && 
            existing().status == 'pending' && 
            incoming().status == 'pending' && 
            incoming().submittedBy == existing().submittedBy &&
            incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'url', 'tags'])
          )
        )
      ));
      
      allow delete: if isValidId(evidenceId) && isAdmin();
    }

    match /users/{userId} {
      // PII Protection: Only admins or the owner can read details. Others can only get for existence/id if public.
      // But for this app, we'll restrict to isOwner or isAdmin to prevent email leak.
      allow read: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow create: if isValidId(userId) && isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isValidId(userId) && ((isAdmin()) || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['username']) && isValidUserProfile(incoming())));
    }

    match /reports/{reportId} {
      allow list: if isAdmin();
      allow get: if isValidId(reportId) && (isAdmin() || isOwner(resource.data.reporterId));
      allow create: if isValidId(reportId) && isSignedIn() && isNotBanned() && isValidReport(incoming());
      allow update, delete: if isValidId(reportId) && isAdmin();
    }

    match /dossier/{profileId} {
      allow read: if true;
      allow create: if isValidId(profileId) && isVerifiedUser() && isNotBanned() && isValidDossierProfile(incoming()) && incoming().status == 'pending' && incoming().submittedBy == request.auth.uid;
      allow update, delete: if isValidId(profileId) && isAdmin();
    }

    match /artists/{artistId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow create: if isValidId(artistId) && isValidArtist(incoming()) && incoming().status == 'pending';
      allow update: if isValidId(artistId) && (
        isAdmin() || 
        // Allow visitors to increment metrics
        (incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['metrics', 'updatedAt'])) ||
        // Allow the submitter to update their profile if they are requesting changes
        (incoming().status == 'pending' && existing().status == 'changes_requested' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'bio', 'shortBio', 'genres', 'profilePicture', 'bannerImage', 'location', 'links', 'featuredSong', 'featuredAlbum', 'featuredVideo', 'status', 'updatedAt']))
      );
      allow delete: if isValidId(artistId) && isAdmin();
    }

    match /artist_updates/{updateId} {
      allow read: if true;
      allow create, update, delete: if isValidId(updateId) && isAdmin() && isValidArtistUpdate(incoming());
    }

    // Admin lookup collection (locked down)
    match /admins/{adminId} {
      allow read: if false; // Only exists() works in rules
      allow write: if false;
    }
  }
}
